# Con "group = 1" definimos un único grupo (cualquier valor constante sirve),
# para que una línea una todos los puntos, en lugar de generar una línea en
# cada valor de X:
stat_summary(geom = 'line',
fun = 'mean',
group = 1,
colour = 'gray') +
# Los puntos, en cambio, son uno para cada grupo:
stat_summary(geom = 'point',
fun = 'mean',
colour = 'red',
size = 2)
ggplot(data = gwas, aes(x = OBS_CT, y = SE)) +
stat_summary(geom = 'line', fun = 'mean', linewidth = 7, color = 'gray') +
geom_point(position = 'jitter', size = 0.1) +
stat_summary(geom = 'point', fun = 'mean', color = 'red', size = 4) +
theme_minimal()
library(phangorn)
mtdna <- read.phyDat('mtDNA.fasta', format = 'fasta')
glance(mtdna)
modelos <- modelTest(mtdna, control = pml.control(trace = 0))
#| fig-width: 5
#| fig-height: 10
mt_nj    <-    NJ(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
mt_upgma <- upgma(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
plot(midpoint(mt_nj))
add.scale.bar()
plot(mt_upgma)
axisPhylo()
#| fig-width: 5
#| fig-height: 10
mt_nj    <-    NJ(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
mt_upgma <- upgma(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
plot(midpoint(mt_nj))
add.scale.bar()
plot(mt_upgma)
axisPhylo()
#| fig-width: 5
#| fig-height: 10
enraizado <- root(mt_nj, 'G.gorilla_D38114')
plot(enraizado)
veros <- pml_bb(mtdna, model = 'GTR+G(4)+I',
control = pml.control(trace = 0))
fit <- as.pml(modelos,'TIM2+G(4)+I')
veros <- pml_bb(fit,
control = pml.control(trace = 0))
#| fig-width: 5
#| fig-height: 10
mt_ml <- root(veros$tree, 'G.gorilla_D38114')
plot(midpoint(mt_ml))
nodelabels()
homo <- extract.clade(mt_ml, 62)
plot(midpoint(homo))
