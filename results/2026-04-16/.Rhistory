library('ggplot2')
gwas <- read.table('gwas.txt')
library('ggplot2')
gwas <- read.table('gwas.txt', header = TRUE)
View(gwas)
ggplot(data = gwas,
mapping = aes(x = BETA / SE, y = T_STAT)) +
geom_point() +
geom_abline(intercept = 0, slope = 1, color = 'red')
ggplot(data = gwas,
mapping = aes(x = P / SE, y = T_STAT)) +
geom_point() +
geom_abline(intercept = 0, slope = 1, color = 'red')
ggplot(data = gwas,
mapping = aes(x = T_STAT , y = P )) +
geom_line() +
ggplot(data = gwas,
mapping = aes(x = T_STAT , y = P )) +
geom_line()
ggplot(data = gwas,
mapping = aes(x = ID , y = A1 )) +
geom_line()
ggplot(data = gwas,
mapping = aes(x = ID , y = A1_FREQ )) +
geom_line()
ggplot(gwas, aes(x=A1_FREQ)) + stat_ecdf() + geom_vline(xintercept=0,5, color='red')
ggplot(gwas, aes(x=A1_FREQ)) + stat_ecdf() + geom_vline(xintercept=0,5, color='red')
ggplot(gwas, aes(x=A1_FREQ)) + stat_ecdf() + geom_vline(xintercept=0.5, color='red')
plot(gwas$A1_FREQ, pch='.')
ggplot(data = gwas,
mapping = aes(x = OBS_CT , y = SE )) +
geom_line()
ggplot(data = gwas,
mapping = aes(x = OBS_CT , y = SE )) +
geom_line()
ggplot(data = gwas,
mapping = aes(x = SE , fill=as.factor(OBS_CT))) +
geom_histogram()
ggplot(gwas, aes(x=P))) +
ggplot(gwas, aes(x=P)) +
geom_histogram()
# OBS_CT no es categórica, pero la tratamos como tal con "factor()".
# Observa que el color aquí se mapea sólo en la capa "geom_smooth()",
# para que los puntos sean todos negros.
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point() +
geom_smooth(mapping = aes(color = factor(OBS_CT)), se = FALSE)
#| fig.width: 10
#| fig.height: 10
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point() +
facet_wrap(~CHROM, scale = 'free')
# OBS_CT no es categórica, pero la tratamos como tal con "factor()".
# Observa que el color aquí se mapea sólo en la capa "geom_smooth()",
# para que los puntos sean todos negros.
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point(mapping = aes(color = factor(OBS_CT)) +
geom_smooth(mapping = aes(color = factor(OBS_CT)), se = FALSE)
# OBS_CT no es categórica, pero la tratamos como tal con "factor()".
# Observa que el color aquí se mapea sólo en la capa "geom_smooth()",
# para que los puntos sean todos negros.
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point(mapping = aes(color = factor(OBS_CT)), se = FALSE) +
geom_smooth(mapping = aes(color = factor(OBS_CT)), se = FALSE)
#| fig.width: 10
#| fig.height: 10
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point() +
facet_wrap(~CHROM, scale = 'free') +
geom_smooth(mapping = aes(color = factor(OBS_CT)), se = FALSE)
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point(mapping = aes(color = factor(OBS_CT)), se = FALSE) +
geom_smooth(mapping = aes(color = factor(OBS_CT)), se = FALSE) +
geom_smooth(mapping = aes(color = factor(CHROM)), se = FALSE)
#| fig.width: 10
#| fig.height: 10
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point() +
facet_wrap(~CHROM, scale = 'free') +
geom_smooth(mapping = aes(color = factor(CHROM)), se = FALSE)
#| fig.width: 10
#| fig.height: 10
#| warning: false
#| warning: false
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point() +
facet_wrap(~CHROM, scale = 'free') +
geom_smooth(mapping = aes(color = factor(CHROM)), se = FALSE)
#| fig.width: 10
#| fig.height: 10
#| warning: false
#| message: false
ggplot(data = gwas,
mapping = aes(x = A1_FREQ, y = SE)) +
geom_point() +
facet_wrap(~CHROM, scale = 'free') +
geom_smooth(mapping = aes(color = factor(CHROM)), se = FALSE)
ggplot(data = gwas,
mapping = aes(x = factor(OBS_CT),
y = SE)) +
geom_violin() +
# Con "group = 1" definimos un único grupo (cualquier valor constante sirve),
# para que una línea una todos los puntos, en lugar de generar una línea en
# cada valor de X:
stat_summary(geom = 'line',
fun = 'mean',
group = 1,
colour = 'gray') +
# Los puntos, en cambio, son uno para cada grupo:
stat_summary(geom = 'point',
fun = 'mean',
colour = 'red',
size = 2)
ggplot(data = gwas, aes(x = OBS_CT, y = SE)) +
stat_summary(geom = 'line', fun = 'mean', linewidth = 7, color = 'gray') +
geom_point(position = 'jitter', size = 0.1) +
stat_summary(geom = 'point', fun = 'mean', color = 'red', size = 4) +
theme_minimal()
library(phangorn)
mtdna <- read.phyDat('mtDNA.fasta', format = 'fasta')
glance(mtdna)
modelos <- modelTest(mtdna, control = pml.control(trace = 0))
#| fig-width: 5
#| fig-height: 10
mt_nj    <-    NJ(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
mt_upgma <- upgma(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
plot(midpoint(mt_nj))
add.scale.bar()
plot(mt_upgma)
axisPhylo()
#| fig-width: 5
#| fig-height: 10
mt_nj    <-    NJ(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
mt_upgma <- upgma(dist.dna(as.DNAbin(mtdna), model = 'TN93', gamma = 0.93))
plot(midpoint(mt_nj))
add.scale.bar()
plot(mt_upgma)
axisPhylo()
#| fig-width: 5
#| fig-height: 10
enraizado <- root(mt_nj, 'G.gorilla_D38114')
plot(enraizado)
veros <- pml_bb(mtdna, model = 'GTR+G(4)+I',
control = pml.control(trace = 0))
fit <- as.pml(modelos,'TIM2+G(4)+I')
veros <- pml_bb(fit,
control = pml.control(trace = 0))
#| fig-width: 5
#| fig-height: 10
mt_ml <- root(veros$tree, 'G.gorilla_D38114')
plot(midpoint(mt_ml))
nodelabels()
homo <- extract.clade(mt_ml, 62)
plot(midpoint(homo))
fechas <- c(0, 0, 0, 0, 0, 0, 0, 0, 0,
-400000,
-39000, -50000, -110000, -110000,
-39820, -40096, -38515, -38310, -39000, -40000, -41210,
-42430, -42540, -43230, -43780, -44290, -44770, -49000,
-50000, -82752, -65000, -122287, -110450,
0, 0, 0, 0, 0, 0, 0, 0, 0)
setNames(fechas, names(mtdna))
fit_td <- pml_bb(mtdna, model = 'GTR+G(4)+I', method = 'tipdated',
tree = enraizado,
tip.dates = fechas, rearrangement = 'NNI',
control = pml.control(trace = 0))
fit_td <- pml_bb(fit, method = 'tipdated',
tree = enraizado,
tip.dates = fechas, rearrangement = 'NNI',
control = pml.control(trace = 0))
fit_td <- pml_bb(mtdna, model = 'TIM2+G(4)+I', method = 'tipdated',
tree = enraizado,
tip.dates = fechas, rearrangement = 'NNI',
ratchet.par = ratchet.control(maxit = 5L),
control = pml.control(trace = 1, maxit = 5))
#| fig-width: 5
#| fig-height: 10
plot(fit_td)
fechas <- c(0, 0, 0, 0, 0, 0, 0, 0, 0,
-400000,
-39000, -50000, -110000, -110000,
-39820, -40096, -38515, -38310, -39000, -40000, -41210,
-42430, -42540, -43230, -43780, -44290, -44770, -49000,
-50000, -82752, -65000, -122287, -110450,
0, 0, 0, 0, 0, 0, 0, 0, 0)
setNames(fechas, names(mtdna))
nodedates <- c(fechas,rep(NA,40))
nodedates(51) <- 6500000
fechas <- c(0, 0, 0, 0, 0, 0, 0, 0, 0,
-400000,
-39000, -50000, -110000, -110000,
-39820, -40096, -38515, -38310, -39000, -40000, -41210,
-42430, -42540, -43230, -43780, -44290, -44770, -49000,
-50000, -82752, -65000, -122287, -110450,
0, 0, 0, 0, 0, 0, 0, 0, 0)
setNames(fechas, names(mtdna))
